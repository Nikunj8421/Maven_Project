pipeline
{
agent any
stages
{
stage ("Scm checkout")
  {steps { git 'https://github.com/Nikunj8421/Maven_Project.git' }}

stage ("Maven Compile")
  {steps{ withMaven(jdk: 'JDK_HOME', maven: 'MVN_HOME', traceability: true) {
     sh 'mvn compile'
}}}

stage ("Maven Test")
  {steps{ withMaven(jdk: 'JDK_HOME', maven: 'MVN_HOME', traceability: true) {
     sh 'mvn test'
}}}

stage ("build the code")
  {steps{ withMaven(jdk: 'JDK_HOME', maven: 'MVN_HOME', traceability: true) {
     sh 'mvn clean -B -DskipTests package'
}}}

}
}
